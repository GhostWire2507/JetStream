<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.jetstream.controllers.ReservationController"
      alignment="TOP_CENTER"
      spacing="20"
      stylesheets="@/css/style.css"
      padding="20">

    <!-- Dashboard Cards -->
    <HBox spacing="20" alignment="CENTER">
        <VBox styleClass="card">
            <Text text="Total Bookings" styleClass="card-title"/>
            <Text fx:id="txtTotalBookings" text="0" styleClass="card-value"/>
        </VBox>
        <VBox styleClass="card">
            <Text text="Total Passengers" styleClass="card-title"/>
            <Text fx:id="txtTotalPassengers" text="0" styleClass="card-value"/>
        </VBox>
    </HBox>

    <!-- Reservation Form -->
    <VBox spacing="10" alignment="CENTER">
        <Text text="Book a Flight" styleClass="title"/>
        <TextField fx:id="txtPassengerName" promptText="Passenger Name"/>
        <TextField fx:id="txtSeatNumber" promptText="Seat Number"/>
        <Button fx:id="btnBook" text="Book" onAction="#onBook"/>
        <Button fx:id="btnBack" text="Back" onAction="#onBack"/>
    </VBox>

    <!-- Table of Reservations -->
    <TableView fx:id="tblReservations" prefHeight="300" prefWidth="600" styleClass="table-view">
        <columns>
            <TableColumn fx:id="colPassengerName" text="Passenger Name"/>
            <TableColumn fx:id="colSeatNumber" text="Seat Number"/>
            <TableColumn fx:id="colFlightNumber" text="Flight Number"/>
            <TableColumn fx:id="colBookingId" text="Booking ID"/>
        </columns>
    </TableView>

</VBox>
