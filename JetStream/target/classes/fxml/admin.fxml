<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.VBox?>
<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.jetstream.controllers.AdminController" spacing="10" alignment="CENTER">
    <children>
        <Label text="Admin Login" styleClass="title"/>
        <TextField fx:id="txtUsername" promptText="Username"/>
        <PasswordField fx:id="txtPassword" promptText="Password"/>
        <Button fx:id="btnLogin" text="Login" onAction="#onLogin"/>
        <Button fx:id="btnBack" text="Back" onAction="#onBack"/>
    </children>
</VBox>
