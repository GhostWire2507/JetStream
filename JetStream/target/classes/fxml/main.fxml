<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<VBox xmlns:fx="http://javafx.com/fxml" alignment="CENTER" spacing="12" stylesheets="@/css/style.css">
    <children>
        <Text text="JetStream — Main Menu" styleClass="title"/>
        <Button fx:id="btnReservation" text="Reservation" onAction="#onReservation" />
        <Button fx:id="btnFlight" text="Flight Management" onAction="#onFlight" />
        <Button fx:id="btnCancellation" text="Cancellation" onAction="#onCancellation" />
        <Button fx:id="btnAdmin" text="Admin Dashboard" onAction="#onAdmin" />
    </children>
    <padding>
        <Insets top="40" right="40" bottom="40" left="40"/>
    </padding>
</VBox>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.jetstream.controllers.MainController" alignment="CENTER" spacing="12" stylesheets="@/css/style.css">
</VBox>