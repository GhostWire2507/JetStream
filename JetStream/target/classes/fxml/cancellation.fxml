<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.VBox?>
<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.jetstream.controllers.CancellationController" spacing="10" alignment="CENTER">
    <children>
        <Label text="Cancellation" styleClass="title"/>
        <TextField fx:id="txtBookingId" promptText="Booking ID"/>
        <Button fx:id="btnCancel" text="Cancel Booking" onAction="#onCancel"/>
        <Button fx:id="btnBack" text="Back" onAction="#onBack"/>
    </children>
</VBox>
